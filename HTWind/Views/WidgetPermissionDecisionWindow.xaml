<ui:FluentWindow
  x:Class="HTWind.WidgetPermissionDecisionWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  xmlns:loc="clr-namespace:HTWind.Localization"
  Title="{loc:Loc WidgetPermissionDialog_Title}"
  Width="560"
  Height="380"
  MinWidth="520"
  MinHeight="340"
  ResizeMode="NoResize"
  ShowInTaskbar="False"
  WindowStartupLocation="CenterOwner"
  WindowBackdropType="Mica"
  ExtendsContentIntoTitleBar="True"
  WindowCornerPreference="Round">
  <Grid Margin="18,14,18,14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <ui:TitleBar Grid.Row="0"
        Title="{loc:Loc WidgetPermissionDialog_Title}"/>

    <ui:Card Grid.Row="1"
        Margin="0,10,0,10"
        Padding="16">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock
          Grid.Row="0"
          FontSize="24"
          FontWeight="SemiBold"
          Text="{loc:Loc WidgetPermissionDialog_Header}"/>

        <TextBlock
          Grid.Row="1"
          Margin="0,8,0,0"
          TextWrapping="Wrap"
          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
          Text="{loc:Loc WidgetPermissionDialog_Description}"/>

        <Grid Grid.Row="2"
            Margin="0,14,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <TextBlock
            Grid.Column="0"
            FontWeight="SemiBold"
            Text="{loc:Loc WidgetPermissionDialog_PermissionLabel}"/>

          <TextBlock
            x:Name="PermissionValueText"
            Grid.Column="1"
            TextWrapping="Wrap"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
        </Grid>

        <Grid Grid.Row="3"
            Margin="0,8,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <TextBlock
            Grid.Column="0"
            FontWeight="SemiBold"
            Text="{loc:Loc WidgetPermissionDialog_WidgetLabel}"/>

          <TextBlock
            x:Name="WidgetValueText"
            Grid.Column="1"
            TextWrapping="Wrap"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
        </Grid>

      </Grid>
    </ui:Card>

    <StackPanel
      Grid.Row="2"
      Orientation="Horizontal"
      HorizontalAlignment="Right">
      <ui:Button
        Margin="0,0,8,0"
        Content="{loc:Loc WidgetPermissionDialog_Deny}"
        Click="Deny_Click"/>
      <ui:Button
        Content="{loc:Loc WidgetPermissionDialog_Allow}"
        Appearance="Primary"
        Click="Allow_Click"/>
    </StackPanel>
  </Grid>
</ui:FluentWindow>
