<ui:FluentWindow
  x:Class="HTWind.CreateWidgetWithEditorWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  xmlns:loc="clr-namespace:HTWind.Localization"
  Title="{loc:Loc CreateWithEditorWindow_Title}"
  Width="560"
  Height="330"
  MinWidth="520"
  MinHeight="300"
  ResizeMode="NoResize"
  ShowInTaskbar="False"
  WindowBackdropType="Mica"
  ExtendsContentIntoTitleBar="True"
  WindowCornerPreference="Round">
  <Grid Margin="18,14,18,14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <ui:TitleBar Grid.Row="0"
        Title="{loc:Loc CreateWithEditorWindow_Title}"/>

    <ui:Card Grid.Row="1"
        Margin="0,10,0,10"
        Padding="16">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock
          Grid.Row="0"
          FontSize="14"
          FontWeight="SemiBold"
          Text="{loc:Loc CreateWithEditorWindow_FileNameLabel}"/>

        <TextBox
          x:Name="FileNameTextBox"
          Grid.Row="1"
          Margin="0,8,0,0"
          MinWidth="420"/>

        <TextBlock
          Grid.Row="2"
          Margin="0,8,0,0"
          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
          Text="{loc:Loc CreateWithEditorWindow_FileNameHint}"
          TextWrapping="Wrap"/>

        <StackPanel
          Grid.Row="3"
          Margin="0,14,0,0"
          Orientation="Horizontal">
          <ui:ToggleSwitch
            x:Name="VisibleByDefaultToggle"
            Margin="0,0,14,0"
            Content="{loc:Loc MainWindow_Visible}"
            IsChecked="True"/>

          <ui:ToggleSwitch
            x:Name="EnableHotReloadToggle"
            Content="{loc:Loc EditorWindow_HotReload}"
            IsChecked="True"/>
        </StackPanel>
      </Grid>
    </ui:Card>

    <StackPanel
      Grid.Row="2"
      HorizontalAlignment="Right"
      Orientation="Horizontal">
      <ui:Button
        Margin="0,0,8,0"
        Content="{loc:Loc CreateWithEditorWindow_Cancel}"
        Click="Cancel_Click"/>
      <ui:Button
        Content="{loc:Loc CreateWithEditorWindow_Create}"
        Appearance="Primary"
        Click="Create_Click"/>
    </StackPanel>
  </Grid>
</ui:FluentWindow>
