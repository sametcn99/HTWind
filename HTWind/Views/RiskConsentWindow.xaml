<ui:FluentWindow
    x:Class="HTWind.RiskConsentWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:loc="clr-namespace:HTWind.Localization"
    Title="{loc:Loc RiskConsentWindow_Title}"
    Icon="/Assets/favicon.ico"
    Width="620"
    Height="430"
    MinWidth="560"
    MinHeight="380"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowBackdropType="Mica"
    ExtendsContentIntoTitleBar="True"
    WindowCornerPreference="Round"
    Closing="Window_Closing">
    <Grid Margin="18,14,18,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{loc:Loc RiskConsentWindow_Title}" />

        <ui:Card Grid.Row="1" Padding="16" Margin="0,10,0,10">
            <StackPanel>
                <TextBlock Text="{loc:Loc RiskConsentWindow_Header}" FontSize="24" FontWeight="SemiBold" />
                <TextBlock
                    Margin="0,10,0,0"
                    TextWrapping="Wrap"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="{loc:Loc RiskConsentWindow_Body}" />
                <TextBlock
                    Margin="0,10,0,0"
                    TextWrapping="Wrap"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="{loc:Loc RiskConsentWindow_Body2}" />
            </StackPanel>
        </ui:Card>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <ui:Button
                Content="{loc:Loc RiskConsentWindow_Accept}"
                Appearance="Primary"
                Click="Accept_Click" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
