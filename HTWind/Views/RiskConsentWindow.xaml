<ui:FluentWindow
  x:Class="HTWind.RiskConsentWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  xmlns:loc="clr-namespace:HTWind.Localization"
  Title="{loc:Loc RiskConsentWindow_Title}"
  Icon="/Assets/favicon.ico"
  Width="700"
  Height="500"
  MinWidth="620"
  MinHeight="420"
  WindowStartupLocation="CenterScreen"
  ResizeMode="NoResize"
  ShowInTaskbar="False"
  WindowBackdropType="Mica"
  ExtendsContentIntoTitleBar="True"
  WindowCornerPreference="Round"
  Closing="Window_Closing">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <ui:TitleBar Grid.Row="0"
        Title="{loc:Loc RiskConsentWindow_Title}"/>

    <ScrollViewer Grid.Row="1"
        VerticalScrollBarVisibility="Auto">
      <Grid Margin="20,14,20,14">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:Card Grid.Row="0"
            Padding="20"
            Margin="0,0,0,12">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border
              Width="52"
              Height="52"
              CornerRadius="26"
              VerticalAlignment="Top"
              Background="{DynamicResource AccentFillColorSecondaryBrush}">
              <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="28"
                FontWeight="Bold"
                Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                Text="!"/>
            </Border>

            <StackPanel Grid.Column="1"
                Margin="16,0,0,0">
              <TextBlock
                Text="{loc:Loc RiskConsentWindow_Header}"
                FontSize="32"
                FontWeight="SemiBold"
                TextWrapping="Wrap"/>
              <TextBlock
                Margin="0,10,0,0"
                Text="{loc:Loc RiskConsentWindow_Body}"
                TextWrapping="Wrap"
                FontSize="17"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
          </Grid>
        </ui:Card>

        <ui:Card Grid.Row="1"
            Padding="20">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border
              Width="32"
              Height="32"
              CornerRadius="16"
              VerticalAlignment="Top"
              Background="{DynamicResource ControlFillColorTertiaryBrush}">
              <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="16"
                FontWeight="SemiBold"
                Text="i"/>
            </Border>

            <TextBlock
              Grid.Column="1"
              Margin="12,2,0,0"
              Text="{loc:Loc RiskConsentWindow_Body2}"
              TextWrapping="Wrap"
              FontSize="16"
              Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
          </Grid>
        </ui:Card>
      </Grid>
    </ScrollViewer>

    <Border
      Grid.Row="2"
      Margin="20,0,20,14"
      Padding="0,12,0,0"
      BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
      BorderThickness="0,1,0,0">
      <StackPanel Orientation="Horizontal"
          HorizontalAlignment="Right">
        <ui:Button
          MinWidth="250"
          Height="40"
          FontWeight="SemiBold"
          AutomationProperties.Name="{loc:Loc RiskConsentWindow_Accept}"
          Content="{loc:Loc RiskConsentWindow_Accept}"
          Appearance="Primary"
          Click="Accept_Click"/>
      </StackPanel>
    </Border>
  </Grid>
</ui:FluentWindow>
