<Window
  x:Class="HTWind.WidgetWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:loc="clr-namespace:HTWind.Localization"
  xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
  Title="{loc:Loc WidgetWindow_Title}"
  Height="300"
  Width="300"
  WindowStyle="None"
  AllowsTransparency="True"
  Background="Transparent"
  Topmost="True"
  ShowInTaskbar="False"
  MinWidth="160"
  MinHeight="100">
  <Grid Background="#01000000">
    <Border x:Name="WidgetChrome"
        Background="#B01A1A1A"
        CornerRadius="10"
        Margin="0">
      <Grid x:Name="WebViewHost"
          Margin="8,28,8,8">
        <wv2:WebView2 Name="webView"
            DefaultBackgroundColor="Transparent"/>
      </Grid>
    </Border>

    <!-- Drag surface sits above WebView2 area to avoid WebView2 airspace issues. -->
    <Border
      Name="DragOverlay"
      Height="20"
      Margin="8,6,8,0"
      VerticalAlignment="Top"
      Background="#70000000"
      CornerRadius="6"
      MouseLeftButtonDown="DragOverlay_MouseLeftButtonDown"
      MouseLeftButtonUp="DragOverlay_MouseLeftButtonUp"
      MouseMove="DragOverlay_MouseMove"
      ToolTip="{loc:Loc WidgetWindow_DragTooltip}">
      <TextBlock
        Text="{loc:Loc WidgetWindow_DragOverlayText}"
        Foreground="White"
        FontSize="11"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        IsHitTestVisible="False"/>
    </Border>

    <Grid Name="ResizeHandles"
        IsHitTestVisible="True"
        Panel.ZIndex="9">
      <Border
        Width="18"
        Height="18"
        HorizontalAlignment="Left"
        VerticalAlignment="Top"
        Cursor="SizeNWSE"
        Background="#BFFFFFFF"
        CornerRadius="3"
        MouseLeftButtonDown="TopLeftGrip_MouseLeftButtonDown"
        MouseLeftButtonUp="ResizeGrip_MouseLeftButtonUp"
        MouseMove="ResizeGrip_MouseMove"/>

      <Border
        Width="18"
        Height="18"
        HorizontalAlignment="Right"
        VerticalAlignment="Top"
        Cursor="SizeNESW"
        Background="#BFFFFFFF"
        CornerRadius="3"
        MouseLeftButtonDown="TopRightGrip_MouseLeftButtonDown"
        MouseLeftButtonUp="ResizeGrip_MouseLeftButtonUp"
        MouseMove="ResizeGrip_MouseMove"/>

      <Border
        Width="18"
        Height="18"
        HorizontalAlignment="Left"
        VerticalAlignment="Bottom"
        Cursor="SizeNESW"
        Background="#BFFFFFFF"
        CornerRadius="3"
        MouseLeftButtonDown="BottomLeftGrip_MouseLeftButtonDown"
        MouseLeftButtonUp="ResizeGrip_MouseLeftButtonUp"
        MouseMove="ResizeGrip_MouseMove"/>

      <Border
        Width="18"
        Height="18"
        HorizontalAlignment="Right"
        VerticalAlignment="Bottom"
        Cursor="SizeNWSE"
        Background="#BFFFFFFF"
        CornerRadius="3"
        MouseLeftButtonDown="BottomRightGrip_MouseLeftButtonDown"
        MouseLeftButtonUp="ResizeGrip_MouseLeftButtonUp"
        MouseMove="ResizeGrip_MouseMove"/>
    </Grid>
  </Grid>
</Window>
