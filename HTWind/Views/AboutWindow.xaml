<ui:FluentWindow
  x:Class="HTWind.AboutWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  xmlns:loc="clr-namespace:HTWind.Localization"
  Title="{loc:Loc AboutWindow_Title}"
  Icon="/Assets/favicon.ico"
  Width="620"
  Height="500"
  MinWidth="560"
  MinHeight="420"
  WindowBackdropType="Mica"
  ExtendsContentIntoTitleBar="True"
  WindowCornerPreference="Round">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <ui:TitleBar Grid.Row="0"
        Title="{loc:Loc AboutWindow_Title}"/>

    <ScrollViewer Grid.Row="1"
        VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="18,14,18,14">
        <ui:Card Padding="16"
            Margin="0,0,0,12">
          <StackPanel>
            <TextBlock Text="{loc:Loc AboutWindow_Heading}"
                FontSize="24"
                FontWeight="SemiBold"/>
            <TextBlock Margin="0,6,0,0"
                Text="{loc:Loc AboutWindow_Description}"
                TextWrapping="Wrap"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
          </StackPanel>
        </ui:Card>

        <ui:Card Padding="16"
            Margin="0,0,0,8">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="{loc:Loc AboutWindow_AppName}"
                  FontWeight="SemiBold"/>
              <TextBlock x:Name="AppNameText"
                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
          </Grid>
        </ui:Card>

        <ui:Card Padding="16"
            Margin="0,0,0,8">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="{loc:Loc AboutWindow_Version}"
                  FontWeight="SemiBold"/>
              <TextBlock x:Name="VersionText"
                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
          </Grid>
        </ui:Card>

        <ui:Card Padding="16"
            Margin="0,0,0,8">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="{loc:Loc AboutWindow_GitHubRepository}"
                  FontWeight="SemiBold"/>
              <TextBlock x:Name="RepositoryText"
                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                  TextWrapping="Wrap"/>
            </StackPanel>
            <ui:Button Grid.Column="1"
                Margin="12,0,0,0"
                Content="{loc:Loc AboutWindow_Open}"
                Click="OpenRepository_Click"/>
          </Grid>
        </ui:Card>

        <ui:Card Padding="16"
            Margin="0,0,0,8">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="{loc:Loc AboutWindow_DeveloperWebsite}"
                  FontWeight="SemiBold"/>
              <TextBlock x:Name="DeveloperSiteText"
                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                  TextWrapping="Wrap"/>
            </StackPanel>
            <ui:Button Grid.Column="1"
                Margin="12,0,0,0"
                Content="{loc:Loc AboutWindow_Open}"
                Click="OpenDeveloperSite_Click"/>
          </Grid>
        </ui:Card>

        <ui:Card Padding="16"
            Margin="0,0,0,8">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="{loc:Loc AboutWindow_Issues}"
                  FontWeight="SemiBold"/>
              <TextBlock x:Name="IssuesText"
                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                  TextWrapping="Wrap"/>
            </StackPanel>
            <ui:Button Grid.Column="1"
                Margin="12,0,0,0"
                Content="{loc:Loc AboutWindow_Open}"
                Click="OpenIssues_Click"/>
          </Grid>
        </ui:Card>

        <ui:Card Padding="16">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="{loc:Loc AboutWindow_Discussions}"
                  FontWeight="SemiBold"/>
              <TextBlock x:Name="DiscussionsText"
                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                  TextWrapping="Wrap"/>
            </StackPanel>
            <ui:Button Grid.Column="1"
                Margin="12,0,0,0"
                Content="{loc:Loc AboutWindow_Open}"
                Click="OpenDiscussions_Click"/>
          </Grid>
        </ui:Card>

        <ui:Card Padding="16"
            Margin="0,8,0,0">
          <StackPanel>
            <TextBlock Text="{loc:Loc AboutWindow_Updates}"
                FontWeight="SemiBold"/>
            <TextBlock
              x:Name="UpdateStatusText"
              Margin="0,6,0,10"
              Text="{loc:Loc AboutWindow_UpdateNotChecked}"
              TextWrapping="Wrap"
              Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            <StackPanel Orientation="Horizontal">
              <ui:Button Content="{loc:Loc AboutWindow_CheckUpdates}"
                  Click="CheckUpdates_Click"/>
              <ui:Button Margin="10,0,0,0"
                  Content="{loc:Loc AboutWindow_OpenLatestRelease}"
                  Click="OpenLatestRelease_Click"/>
            </StackPanel>
          </StackPanel>
        </ui:Card>
      </StackPanel>
    </ScrollViewer>

    <StackPanel Grid.Row="2"
        Orientation="Horizontal"
        HorizontalAlignment="Right"
        Margin="0,0,16,14">
      <ui:Button Content="{loc:Loc AboutWindow_Close}"
          Click="Close_Click"/>
    </StackPanel>
  </Grid>
</ui:FluentWindow>
